# Site — use your production domain (required for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Admin dashboard (/admin)
ADMIN_PASSWORD=your-secure-password

# Database (Neon)
DATABASE_URL=postgresql://...

# Stripe Checkout
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret (required for booking emails + reliable fulfillment)
# Create at https://dashboard.stripe.com/webhooks → endpoint:
#   https://your-domain.com/api/webhooks/stripe
# Events: checkout.session.completed, checkout.session.expired
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Dream Scape Moments <bookings@yourdomain.com>"

# Inbox for new bookings and quote enquiries
BOOKING_NOTIFICATION_EMAIL=you@yourdomain.com
QUOTE_NOTIFICATION_EMAIL=you@yourdomain.com

# Optional: Vercel Blob for quote form photos
BLOB_READ_WRITE_TOKEN=

# Optional: social links
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TIKTOK_URL=
